---
import { getCollection } from 'astro:content';
import Page from '../layouts/Page.astro';

const allPosts = await getCollection('feed');
allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const dayMap = new Map<string, typeof allPosts>();
for (const post of allPosts) {
  const key = post.data.date.toISOString().slice(0, 10);
  if (!dayMap.has(key)) dayMap.set(key, []);
  dayMap.get(key)!.push(post);
}

const renderedDays = await Promise.all(
  [...dayMap.entries()].map(async ([dateStr, posts]) => {
    const rendered = await Promise.all(
      posts.map(async (post) => {
        const { Content } = await post.render();
        return { post, Content };
      })
    );
    return { dateStr, rendered };
  })
);

renderedDays.sort((a, b) => b.dateStr.localeCompare(a.dateStr));
const dateKeys = renderedDays.map(d => d.dateStr);
---

<Page title="Tim Haley" noFooter={true}>
  <div class="feed-content">
    <div id="all-days">
      {renderedDays.map(({ dateStr, rendered }) => (
        <div class="day" data-date={dateStr} style="display:none">
          {rendered.map(({ post, Content }) => (
            <article class="post">
              <div class="post-header">
                {post.data.time && (
                  <span class="post-time">{post.data.time}</span>
                )}
                {post.data.tags.length > 0 && (
                  <div class="post-tags">
                    {post.data.tags.map(tag => (
                      <span class="tag-chip">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
              {post.data.title && <h4 class="post-title">{post.data.title}</h4>}
              <div class="post-content">
                <Content />
              </div>
            </article>
          ))}
        </div>
      ))}
    </div>
  </div>

  <div class="day-nav-bar">
    <hr class="nav-hr" />
    <div class="day-nav-inner">
    <nav class="day-nav">
      <button class="nav-side nav-prev" id="prev-btn" aria-label="Previous day">
        <span class="nav-arrow">←</span>
        <span class="nav-date" id="prev-date"></span>
      </button>
      <button class="crystal-btn" id="crystal-btn" title="I'm feeling lucky!" aria-label="Random day">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M 21,12 19.6,16.4 16.3,19.4 12,20.4 7.9,19.1 5.1,16 4.3,12 5.5,8.2 8.3,5.6 12,4.9 15.5,6 17.8,8.6 18.5,12 17.4,15.1 15,17.3 12,17.9 9.2,16.9 7.3,14.7 6.8,12 7.6,9.5 9.6,7.8 12,7.4 14.2,8.2 15.6,9.9 16,12 15.3,13.9 13.8,15.1 12,15.4 10.4,14.7 9.4,13.5 9.3,12 9.8,10.7 10.8,10 12,9.9 13,10.3 13.5,11.1 13.5,12"/>
        </svg>
      </button>
      <button class="nav-side nav-next" id="next-btn" aria-label="Next day">
        <span class="nav-arrow">→</span>
        <span class="nav-date" id="next-date"></span>
      </button>
    </nav>
    </div>
  </div>
</Page>

<script define:vars={{ dateKeys }}>
  function formatDateLong(str) {
    const [y, m, d] = str.split('-').map(Number);
    return new Date(y, m - 1, d).toLocaleDateString('en-US', {
      year: 'numeric', month: 'long', day: 'numeric',
    });
  }

  function formatDateShort(str) {
    const [y, m, d] = str.split('-').map(Number);
    const date = new Date(y, m - 1, d);
    const month = date.toLocaleDateString('en-US', { month: 'short' });
    const year = String(y).slice(2);
    return `${month} ${d}, '${year}`;
  }

  function getCurrentDate() {
    const hash = window.location.hash.slice(1);
    return dateKeys.includes(hash) ? hash : dateKeys[0];
  }

  const prevBtn = document.getElementById('prev-btn');
  const nextBtn = document.getElementById('next-btn');
  const prevDateEl = document.getElementById('prev-date');
  const nextDateEl = document.getElementById('next-date');
  const crystalBtn = document.getElementById('crystal-btn');
  const currentDateLabel = document.getElementById('current-date-label');

  function render(dateStr) {
    document.querySelectorAll('.day').forEach(el => {
      el.style.display = el.dataset.date === dateStr ? '' : 'none';
    });

    currentDateLabel.textContent = formatDateLong(dateStr);

    const idx = dateKeys.indexOf(dateStr);
    const prevDate = idx < dateKeys.length - 1 ? dateKeys[idx + 1] : null;
    const nextDate = idx > 0 ? dateKeys[idx - 1] : null;

    prevBtn.disabled = !prevDate;
    prevDateEl.textContent = prevDate ? formatDateShort(prevDate) : '';

    nextBtn.disabled = !nextDate;
    nextDateEl.textContent = nextDate ? formatDateShort(nextDate) : '';
  }

  prevBtn.addEventListener('click', () => {
    const idx = dateKeys.indexOf(getCurrentDate());
    if (idx < dateKeys.length - 1) window.location.hash = dateKeys[idx + 1];
  });

  nextBtn.addEventListener('click', () => {
    const idx = dateKeys.indexOf(getCurrentDate());
    if (idx > 0) window.location.hash = dateKeys[idx - 1];
  });

  crystalBtn.addEventListener('click', () => {
    crystalBtn.classList.remove('spinning');
    void crystalBtn.offsetWidth;
    crystalBtn.classList.add('spinning');

    const current = getCurrentDate();
    const others = dateKeys.filter(d => d !== current);
    const target = others.length > 0 ? others[Math.floor(Math.random() * others.length)] : current;

    setTimeout(() => { window.location.hash = target; }, 400);
  });

  crystalBtn.addEventListener('animationend', (e) => {
    if (e.animationName === 'spiral-cw') crystalBtn.classList.remove('spinning');
  });

  window.addEventListener('keydown', (e) => {
    if (datePicker.classList.contains('open')) {
      if (e.key === 'Escape') closeCalendar();
      return;
    }
    if (e.key === 'ArrowLeft') prevBtn.click();
    if (e.key === 'ArrowRight') nextBtn.click();
  });

  // --- Calendar ---

  const datePicker = document.getElementById('date-picker');
  const datePickerBtn = document.getElementById('date-picker-btn');
  const calendar = document.getElementById('calendar');
  const calGrid = document.getElementById('cal-grid');
  const calMonthLabel = document.getElementById('cal-month-label');
  const calPrevBtn = document.getElementById('cal-prev');
  const calNextBtn = document.getElementById('cal-next');

  const dateKeySet = new Set(dateKeys);
  let calYear, calMonth;

  function openCalendar() {
    const [y, m] = getCurrentDate().split('-').map(Number);
    renderCalendar(y, m - 1);
    calendar.classList.add('open');
    datePicker.classList.add('open');
  }

  function closeCalendar() {
    calendar.classList.remove('open');
    datePicker.classList.remove('open');
  }

  function renderCalendar(year, month) {
    calYear = year;
    calMonth = month;

    calMonthLabel.textContent = new Date(year, month).toLocaleDateString('en-US', {
      month: 'long', year: 'numeric',
    });

    const firstDay = new Date(year, month, 1).getDay();
    const daysInMonth = new Date(year, month + 1, 0).getDate();
    const current = getCurrentDate();

    calGrid.innerHTML = '';

    for (let i = 0; i < firstDay; i++) {
      calGrid.appendChild(document.createElement('span'));
    }

    for (let day = 1; day <= daysInMonth; day++) {
      const dateStr = `${year}-${String(month + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
      const btn = document.createElement('button');
      btn.textContent = day;
      btn.classList.add('cal-day');

      if (dateKeySet.has(dateStr)) {
        btn.classList.add('has-posts');
        if (dateStr === current) btn.classList.add('selected');
        btn.addEventListener('click', () => {
          window.location.hash = dateStr;
          closeCalendar();
        });
      }

      calGrid.appendChild(btn);
    }
  }

  datePickerBtn.addEventListener('click', () => {
    datePicker.classList.contains('open') ? closeCalendar() : openCalendar();
  });

  calPrevBtn.addEventListener('click', () => {
    let m = calMonth - 1, y = calYear;
    if (m < 0) { m = 11; y--; }
    renderCalendar(y, m);
  });

  calNextBtn.addEventListener('click', () => {
    let m = calMonth + 1, y = calYear;
    if (m > 11) { m = 0; y++; }
    renderCalendar(y, m);
  });

  document.addEventListener('click', (e) => {
    if (!datePicker.contains(e.target)) closeCalendar();
  });

  window.addEventListener('hashchange', () => render(getCurrentDate()));
  render(getCurrentDate());
</script>

<style>
  .post {
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--border);
  }

  .post:last-child {
    border-bottom: none;
  }

  .post-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .post-time {
    font-family: var(--font-ui);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .post-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-left: auto;
  }

  .tag-chip {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--text-muted);
    background: none;
    border: none;
    padding: 0;
  }

  .tag-chip::before {
    content: '#';
  }

  .post-title {
    font-family: var(--font-prose);
    line-height: 1.3;
    margin: 2.25rem 0 0.75rem;
  }

  .post-content {
    font-family: var(--font-prose);
    line-height: 1.75;
  }

  .post-content :global(p) {
    margin-bottom: 1rem;
  }

  .post-content :global(p:last-child) {
    margin-bottom: 0;
  }

  .post-content :global(a) {
    color: var(--accent);
  }

  .post-content :global(a:hover) {
    color: var(--accent-hover);
  }

  .post-content :global(blockquote) {
    margin: 0.75rem 0;
    padding: 0.4rem 1rem;
    border-left: 3px solid var(--accent);
    font-style: italic;
    color: var(--text-muted);
  }

  .post-content :global(blockquote blockquote) {
    margin: 0.5rem 0 0;
    border-left-color: var(--text-dim);
  }

  /* Headings */
  .post-content :global(h1),
  .post-content :global(h2),
  .post-content :global(h3),
  .post-content :global(h4),
  .post-content :global(h5),
  .post-content :global(h6) {
    font-family: var(--font-prose);
    color: var(--text);
    margin: 2.25rem 0 0.75rem;
    line-height: 1.3;
  }

  .post-content :global(h1) { font-size: 1.6rem; }
  .post-content :global(h2) { font-size: 1.35rem; }
  .post-content :global(h3) { font-size: 1.15rem; }
  .post-content :global(h4) { font-size: 1rem; }
  .post-content :global(h5),
  .post-content :global(h6) { font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.04em; }

  /* Lists */
  .post-content :global(ul),
  .post-content :global(ol) {
    padding-left: 1.4rem;
    margin-bottom: 0.75rem;
  }

  .post-content :global(li) {
    margin-bottom: 0.3rem;
    line-height: 1.65;
  }

  .post-content :global(li > ul),
  .post-content :global(li > ol) {
    margin-top: 0.3rem;
    margin-bottom: 0;
  }

  /* Task lists */
  .post-content :global(.task-list-item) {
    list-style: none;
    margin-left: -1.4rem;
    padding-left: 0;
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }

  .post-content :global(.task-list-item input[type="checkbox"]) {
    accent-color: var(--accent);
    margin: 0;
    flex-shrink: 0;
    position: relative;
    top: 0.1em;
  }

  /* Code */
  .post-content :global(code) {
    font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace;
    font-size: 0.82em;
    background: var(--surface);
    color: var(--text);
    padding: 0.15em 0.35em;
    border-radius: 3px;
    border: 1px solid var(--border);
  }

  .post-content :global(pre) {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 1rem 1.1rem;
    overflow-x: auto;
    margin: 0.75rem 0;
  }

  .post-content :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: 0.82rem;
    line-height: 1.6;
  }

  /* Tables */
  .post-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
    margin: 0.75rem 0;
  }

  .post-content :global(th) {
    font-family: var(--font-ui);
    font-weight: 700;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-muted);
    text-align: left;
    padding: 0.5rem 0.75rem;
    border-bottom: 2px solid var(--border);
  }

  .post-content :global(td) {
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--border);
    vertical-align: top;
  }

  .post-content :global(tr:last-child td) {
    border-bottom: none;
  }

  /* Horizontal rules within content */
  .post-content :global(hr) {
    margin: 2.25rem 0;
    border: none;
    border-top: 1px solid var(--border);
  }

  /* Images */
  .post-content :global(img) {
    max-width: 100%;
    border-radius: 4px;
    margin: 0.5rem 0;
  }

  /* Strong / em inherit --font-prose */
  .post-content :global(strong) { font-weight: 700; }
  .post-content :global(em) { font-style: italic; }

  /* --- Fixed day nav --- */

  .day-nav-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: var(--bg);
    z-index: 100;
  }

  .day-nav-inner {
    max-width: 800px;
    margin: 0 auto;
  }

  .nav-hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 0;
  }

  .day-nav {
    padding: 0.85rem 2rem;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
  }

  .nav-side {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    min-width: 5rem;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    font-family: inherit;
  }

  .nav-side:disabled {
    cursor: default;
  }

  .nav-prev {
    align-items: flex-start;
  }

  .nav-next {
    align-items: flex-end;
  }

  .nav-arrow {
    font-size: 1.3rem;
    color: var(--text);
    line-height: 1;
    transition: color 0.15s;
  }

  .nav-side:disabled .nav-arrow {
    color: var(--text-dim);
  }

  .nav-side:not(:disabled):hover .nav-arrow {
    color: var(--accent);
  }

  .nav-date {
    font-family: var(--font-ui);
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--text-muted);
    min-height: 1em;
    transition: color 0.15s;
  }

  .nav-side:not(:disabled):hover .nav-date {
    text-decoration: underline;
    color: var(--accent);
  }

  .crystal-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    display: inline-flex;
    align-items: center;
    transition: transform 0.15s, color 0.15s;
    transform-origin: center;
    align-self: center;
    color: var(--text-muted);
  }

  .crystal-btn svg {
    width: 1.3rem;
    height: auto;
    transform-box: view-box;
    transform-origin: 50% 50%;
  }

  .crystal-btn:hover:not(.spinning) {
    transform: scale(1.2);
    color: var(--text);
  }

  .crystal-btn:hover:not(.spinning) svg {
    animation: spiral-ccw 10s linear infinite;
  }

  @keyframes spiral-ccw {
    to { transform: rotate(-360deg); }
  }

  @keyframes spiral-cw {
    to { transform: rotate(360deg); }
  }

  .crystal-btn.spinning svg {
    animation: spiral-cw 0.75s cubic-bezier(0.600, -0.280, 0.735, 0.045) both;
  }
</style>
